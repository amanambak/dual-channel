{
  "version": 1,
  "categories": [
    {
      "id": "loan_requirement",
      "label": "Loan Requirement",
      "priority": 20,
      "topic_triggers": [
        "loan",
        "amount",
        "top up",
        "balance transfer",
        "home loan",
        "lap",
        "bt",
        "emi",
        "roi",
        "tenure"
      ],
      "base_required_fields": [
        "loan_type",
        "loan_amount"
      ],
      "field_priority": [
        "loan_type",
        "loan_amount",
        "remaining_loan_amount",
        "previous_current_roi",
        "previous_loan_amount",
        "previous_emi_amount",
        "previous_tenure",
        "previous_loan_start_date",
        "is_property_identified"
      ],
      "branches": [
        {
          "id": "home_loan",
          "label": "Home loan",
          "when": {
            "field": "loan_type",
            "operator": "equals_any",
            "value": [
              "1",
              "home loan",
              "home"
            ]
          },
          "required_fields": [
            "is_property_identified"
          ]
        },
        {
          "id": "balance_transfer",
          "label": "Balance transfer",
          "when": {
            "field": "loan_type",
            "operator": "equals_any",
            "value": [
              "4",
              "balance transfer",
              "bt"
            ]
          },
          "required_fields": [
            "previous_loan_amount",
            "previous_emi_amount",
            "previous_loan_start_date",
            "previous_tenure",
            "previous_current_roi",
            "remaining_loan_amount"
          ]
        },
        {
          "id": "top_up",
          "label": "Top-up",
          "when": {
            "field": "loan_type",
            "operator": "equals_any",
            "value": [
              "3",
              "top up",
              "top-up",
              "topup"
            ]
          },
          "required_fields": [
            "previous_loan_amount",
            "remaining_loan_amount",
            "previous_current_roi"
          ]
        }
      ]
    },
    {
      "id": "customer_details",
      "label": "Customer Details",
      "base_required_fields": [
        "customer_first_name",
        "customer_last_name",
        "customer_gender",
        "customer_dob",
        "customer_email",
        "customer_mobile",
        "customer_pan",
        "customer_aadhaar",
        "customer_marital_status",
        "customer_pincode",
        "customer_state",
        "customer_city",
        "customer_address_line1",
        "customer_address_line2",
        "customer_mother_name",
        "customer_qualification",
        "customer_preferred_language",
        "customer_office_address",
        "customer_dependents",
        "customer_designation",
        "customer_occupation",
        "customer_official_email",
        "has_co_applicant"
      ],
      "field_priority": [
        "customer_first_name",
        "customer_last_name",
        "customer_mobile",
        "customer_dob",
        "customer_pan",
        "customer_aadhaar",
        "customer_gender",
        "customer_email",
        "customer_marital_status",
        "customer_pincode",
        "customer_city",
        "customer_state",
        "customer_address_line1",
        "customer_address_line2",
        "customer_mother_name",
        "customer_qualification",
        "customer_preferred_language",
        "customer_office_address",
        "customer_dependents",
        "customer_designation",
        "customer_occupation",
        "customer_official_email",
        "has_co_applicant"
      ],
      "sections": [
        {
          "id": "person_identity",
          "label": "Person Identity",
          "fields": [
            "customer_first_name",
            "customer_last_name",
            "customer_gender",
            "customer_dob",
            "customer_marital_status",
            "customer_mother_name",
            "customer_qualification",
            "customer_preferred_language",
            "customer_spouse_name"
          ]
        },
        {
          "id": "contact_kyc",
          "label": "Contact and KYC",
          "fields": [
            "customer_mobile",
            "customer_email",
            "customer_pan",
            "customer_aadhaar"
          ]
        },
        {
          "id": "address",
          "label": "Address",
          "fields": [
            "customer_pincode",
            "customer_state",
            "customer_city",
            "customer_address_line1",
            "customer_address_line2"
          ]
        },
        {
          "id": "employment_snapshot",
          "label": "Employment Snapshot",
          "fields": [
            "customer_occupation",
            "customer_designation",
            "customer_office_address",
            "customer_official_email",
            "customer_dependents"
          ]
        },
        {
          "id": "co_applicant",
          "label": "Co-applicant",
          "fields": [
            "has_co_applicant"
          ]
        }
      ],
      "branches": [
        {
          "id": "married_customer",
          "label": "Married customer",
          "when": {
            "field": "customer_marital_status",
            "operator": "equals_any",
            "value": [
              "married",
              "1"
            ]
          },
          "required_fields": [
            "customer_spouse_name"
          ]
        },
        {
          "id": "customer_address_incomplete",
          "label": "Customer address incomplete",
          "when": {
            "field": "customer_pincode",
            "operator": "exists"
          },
          "required_fields": [
            "customer_state",
            "customer_city",
            "customer_address_line1"
          ]
        },
        {
          "id": "co_applicant_present",
          "label": "Co-applicant present",
          "when": {
            "field": "has_co_applicant",
            "operator": "truthy"
          },
          "required_fields": [
            "coapplicant_relationship",
            "coapplicant_first_name",
            "coapplicant_last_name",
            "coapplicant_dob",
            "coapplicant_email",
            "coapplicant_mobile",
            "coapplicant_qualification",
            "coapplicant_mother_name",
            "coapplicant_type",
            "coapplicant_marital_status",
            "coapplicant_pan",
            "coapplicant_gender",
            "coapplicant_aadhaar",
            "coapplicant_same_as_customer_address",
            "coapplicant_office_address",
            "coapplicant_occupation",
            "coapplicant_official_email",
            "coapplicant_designation",
            "coapplicant_total_work_experience",
            "coapplicant_current_job_years",
            "coapplicant_company_name"
          ]
        },
        {
          "id": "married_coapplicant",
          "label": "Married co-applicant",
          "when": {
            "all": [
              {
                "field": "has_co_applicant",
                "operator": "truthy"
              },
              {
                "field": "coapplicant_marital_status",
                "operator": "equals_any",
                "value": [
                  "married",
                  "1"
                ]
              }
            ]
          },
          "required_fields": [
            "coapplicant_spouse_name"
          ]
        },
        {
          "id": "coapplicant_address_required",
          "label": "Co-applicant address required",
          "when": {
            "all": [
              {
                "field": "has_co_applicant",
                "operator": "truthy"
              },
              {
                "field": "coapplicant_same_as_customer_address",
                "operator": "equals_any",
                "value": [
                  "0",
                  "no",
                  "different"
                ]
              }
            ]
          },
          "required_fields": [
            "coapplicant_pincode",
            "coapplicant_state",
            "coapplicant_city",
            "coapplicant_address_line1",
            "coapplicant_address_line2"
          ]
        }
      ],
      "priority": 10
    },
    {
