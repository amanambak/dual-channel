          ]
        },
        {
          "id": "self_employed",
          "label": "Self-employed",
          "when": {
            "field": "profession",
            "operator": "matches_any",
            "value": [
              "2",
              "self-employed",
              "self employed",
              "business"
            ]
          },
          "required_fields": [
            "income_calculation_mode"
          ]
        }
      ]
    },
